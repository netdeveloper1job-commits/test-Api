{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "config/*.env",
        "outDir": "dist"
      },
       {
        "include": "common/helper/pdf-generator/templates/**/*",
        "outDir": "dist"
        
      },
      {
        "include": "common/helper/mail/templates/**/*",
        "outDir": "dist"

      }   ]
  }
}
